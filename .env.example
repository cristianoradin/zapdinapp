# ============================================================
#  ZapDin APP — Configuração de Produção
#  Copie este arquivo para .env e preencha os valores reais.
#  NUNCA commite o .env real no git.
# ============================================================

# Estado do sistema: 'locked' = aguardando ativação | 'active' = operacional
APP_STATE=locked

PORT=4000
DATABASE_URL=data/app.db

# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TROQUE_POR_VALOR_SECRETO_ALEATORIO

# ── Monitor ───────────────────────────────────────────────────────────────────
# URL do Monitor central (servidor do desenvolvedor)
# Em produção: http://SEU_IP_OU_DOMINIO:5000
MONITOR_URL=http://SEU_SERVIDOR:5000

# Token de autenticação deste posto no Monitor
# Corresponde ao campo 'token' do cliente cadastrado no Monitor
# Preenchido automaticamente pelo fluxo de ativação
MONITOR_CLIENT_TOKEN=

# ── Dados do cliente (preenchidos automaticamente na ativação) ─────────────────
CLIENT_NAME=
CLIENT_CNPJ=

# ── Token ERP (gerado no painel ou pelo instalador) ───────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
ERP_TOKEN=

# ── GitHub (auto-update via Velopack) ─────────────────────────────────────────
GITHUB_REPO=cristianoradin/ZapDin2
